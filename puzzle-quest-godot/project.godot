; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the raw format is still documented here:
; https://docs.godotengine.org/en/stable/tutorials/io/config_files.html

config_version=5

[application]

config/name="Puzzle Quest Engine"
config/description="A modular match-3 RPG puzzle game engine inspired by Puzzle Quest"
config/version="1.0.0"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://assets/icons/icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"

[autoload]

GameData="*res://scripts/autoloads/GameData.gd"
EventBus="*res://scripts/autoloads/EventBus.gd"
AudioManager="*res://scripts/autoloads/AudioManager.gd"
